rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regla base: El usuario debe estar autenticado y solo acceder a su propio UID
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Permitir acceso a todas las subcolecciones del usuario (transactions, accounts, goals, categories)
      match /{allPaths=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Denegar todo lo demás por defecto
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
